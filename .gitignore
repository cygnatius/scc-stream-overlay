# Local, machine-specific config that may contain secrets (Pairingsman token, host)
config.local.js
config.local.json

# Runtime config store written by the admin page / server. pairingsman.json
# carries the bearer token — never commit these. Defaults live in server.js.
config/*.json

# Venue media dropped in by the operator (sponsor logos, player photos,
# videos, background music)
assets/sponsors/*
assets/players/*
assets/video/*
assets/music/*

# Your own filled-in working copies (keep the tracked overlays clean)
*.local.html

# OS / editor junk
.DS_Store
Thumbs.db
desktop.ini
*.swp
*~
.vscode/
.idea/

# keep the empty asset folders in git so fresh clones have the drop targets
!assets/sponsors/.gitkeep
!assets/players/.gitkeep
!assets/video/.gitkeep
!assets/music/.gitkeep
